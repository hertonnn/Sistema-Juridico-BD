# ============================================================
# Configuração da API NL-to-SQL Jurídico/Contábil
# Copie este arquivo para .env e ajuste os valores.
# ============================================================

# --- Camada 1: NER ---
# Exemplo com Ollama local:
NER_MODEL=ollama/gemma2:2b
NER_API_BASE=http://localhost:11434
NER_API_KEY=ollama

# Exemplo com OpenRouter:
# NER_MODEL=openrouter/meta-llama/llama-3-8b-instruct
# NER_API_BASE=https://openrouter.ai/api/v1
# NER_API_KEY=sk-or-v1-...

# Exemplo com OpenAI:
# NER_MODEL=gpt-4o-mini
# NER_API_BASE=https://api.openai.com/v1
# NER_API_KEY=sk-...

# --- Camada 2: Geração de SQL ---
# Pode usar o mesmo modelo ou um diferente (ex: modelo maior para SQL)
SQL_MODEL=ollama/gemma2:2b
SQL_API_BASE=http://localhost:11434
SQL_API_KEY=ollama

# Exemplo com OpenAI (modelo mais capaz para SQL complexo):
# SQL_MODEL=gpt-4o
# SQL_API_BASE=https://api.openai.com/v1
# SQL_API_KEY=sk-...

# --- Configurações Gerais ---
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
